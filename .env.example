# Telegram Bot Token — get from @BotFather on Telegram (see docs/setup-telegram-bot.md)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Google Gemini API Key — get from https://aistudio.google.com/apikey (see docs/setup-gemini-api.md)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Optional: Path to yt-dlp binary (see docs/setup-ytdlp.md)
# On Windows with pip install, the bot auto-detects this — leave unset unless auto-detection fails
# YTDLP_PATH=C:\Users\stavh\AppData\Local\Programs\Python\Python312\Scripts\yt-dlp.exe

# Optional: yt-dlp timeout in milliseconds (default: 30000)
# YTDLP_TIMEOUT_MS=30000

# Optional: Instagram auth via cookies (see docs/setup-instagram-auth.md)
# Use one of the following if you hit rate limits or private post errors:
# YTDLP_COOKIES_BROWSER=chrome
# YTDLP_COOKIES_FILE=cookies.txt

# Optional: Max caption length sent to Gemini in characters (default: 8000)
# MAX_CAPTION_LENGTH=8000
